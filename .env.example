# MongoDB connection string.
# Local dev default (started for you): mongodb://127.0.0.1:27017
# For the actual hackathon demo, replace with your own MongoDB Atlas free-tier URI.
# Do NOT point this at any production/Fairdeal connection string.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=industrial_safety

# Anthropic API key for RAG generation + incident report drafting.
# (Unused while AWS_BEDROCK_BEARER_TOKEN below is set -- Bedrock takes priority.)
ANTHROPIC_API_KEY=

# Model used for RAG generation / report drafting when calling the direct
# Anthropic API (i.e. when AWS_BEDROCK_BEARER_TOKEN is NOT set).
ANTHROPIC_MODEL=claude-sonnet-5

# --- AWS Bedrock (takes priority over the direct Anthropic API above) ---
# Bearer-token auth for Bedrock (simpler than full SigV4/IAM credentials).
AWS_BEDROCK_BEARER_TOKEN=
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_REGION=us-east-1

# Engine service config
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
RISK_POLL_INTERVAL_SECONDS=2.5
RED_THRESHOLD=70
YELLOW_THRESHOLD=40
